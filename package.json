{
  "name": "latextoolbox",
  "displayName": "LatexToolBox",
  "description": "Convenient tools for writing LaTeX in VS Code.",
  "version": "0.0.4",
  "publisher": "shenyt",
  "repository": {
    "type": "git",
    "url": "https://github.com/shenytzzz/LatexToolBox.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:latex-toolbox.boldSelection",
    "onCommand:latex-toolbox.insertClipboardImage",
    "onCommand:latex-toolbox.insertImageFromFile",
    "onCommand:latex-toolbox.insertTemplateFiles",
    "onCommand:latex-toolbox.insertTemplateBoxSnippet",
    "onCommand:latex-toolbox.italicSelection",
    "onCommand:latex-toolbox.mergeSelectionIntoSubfigures",
    "onCommand:latex-toolbox.registerMathSymbolReplacement",
    "onCommand:latex-toolbox.underlineSelection",
    "onCommand:latex-toolbox.unmergeSelectionFromSubfigures",
    "onCommand:latex-toolbox.unwrapSelectionFromWrapFigure",
    "onCommand:latex-toolbox.updateTemplateStyleFile",
    "onCommand:latex-toolbox.wrapSelectionWithWrapFigure",
    "onLanguage:latex"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "latex-toolbox.boldSelection",
        "title": "LatexToolBox: Bold Selection"
      },
      {
        "command": "latex-toolbox.italicSelection",
        "title": "LatexToolBox: Italic Selection"
      },
      {
        "command": "latex-toolbox.insertClipboardImage",
        "title": "LatexToolBox: Insert Clipboard Image"
      },
      {
        "command": "latex-toolbox.insertImageFromFile",
        "title": "LatexToolBox: Insert Image from File"
      },
      {
        "command": "latex-toolbox.insertTemplateFiles",
        "title": "LatexToolBox: Insert LaTeX Template Files"
      },
      {
        "command": "latex-toolbox.insertTemplateBoxSnippet",
        "title": "LatexToolBox: Insert Template Box Snippet"
      },
      {
        "command": "latex-toolbox.updateTemplateStyleFile",
        "title": "LatexToolBox: Update LaTeX Template Style File"
      },
      {
        "command": "latex-toolbox.mergeSelectionIntoSubfigures",
        "title": "LatexToolBox: Merge Selected Figures into Subfigures"
      },
      {
        "command": "latex-toolbox.unmergeSelectionFromSubfigures",
        "title": "LatexToolBox: Unmerge Subfigures into Figures"
      },
      {
        "command": "latex-toolbox.unwrapSelectionFromWrapFigure",
        "title": "LatexToolBox: Unwrap Wrapfigure"
      },
      {
        "command": "latex-toolbox.registerMathSymbolReplacement",
        "title": "LatexToolBox: Register Math Symbol Replacement"
      },
      {
        "command": "latex-toolbox.underlineSelection",
        "title": "LatexToolBox: Underline Selection"
      },
      {
        "command": "latex-toolbox.wrapSelectionWithWrapFigure",
        "title": "LatexToolBox: Wrap Selection with Wrapfigure"
      }
    ],
    "keybindings": [
      {
        "command": "-workbench.action.toggleSidebarVisibility",
        "key": "ctrl+b",
        "mac": "cmd+b",
        "when": "editorTextFocus && editorLangId == latex && !editorReadonly"
      },
      {
        "command": "latex-toolbox.boldSelection",
        "key": "ctrl+b",
        "mac": "cmd+b",
        "when": "editorTextFocus && editorLangId == latex && !editorReadonly"
      },
      {
        "command": "-inlineChat.start",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus && editorLangId == latex && !editorReadonly"
      },
      {
        "command": "latex-toolbox.italicSelection",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus && editorLangId == latex && !editorReadonly"
      },
      {
        "command": "-cursorUndo",
        "key": "ctrl+u",
        "mac": "cmd+u",
        "when": "editorTextFocus && editorLangId == latex && !editorReadonly"
      },
      {
        "command": "latex-toolbox.underlineSelection",
        "key": "ctrl+u",
        "mac": "cmd+u",
        "when": "editorTextFocus && editorLangId == latex && !editorReadonly"
      }
    ],
    "snippets": [
      {
        "language": "latex",
        "path": "./snippets/latex.json"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "latex-toolbox.boldSelection",
          "when": "editorLangId == latex && editorHasSelection",
          "group": "navigation"
        },
        {
          "command": "latex-toolbox.italicSelection",
          "when": "editorLangId == latex && editorHasSelection",
          "group": "navigation"
        },
        {
          "command": "latex-toolbox.underlineSelection",
          "when": "editorLangId == latex && editorHasSelection",
          "group": "navigation"
        },
        {
          "command": "latex-toolbox.insertClipboardImage",
          "when": "editorLangId == latex",
          "group": "navigation"
        },
        {
          "command": "latex-toolbox.insertImageFromFile",
          "when": "editorLangId == latex",
          "group": "navigation"
        },
        {
          "command": "latex-toolbox.insertTemplateBoxSnippet",
          "when": "editorLangId == latex",
          "group": "navigation"
        },
        {
          "command": "latex-toolbox.mergeSelectionIntoSubfigures",
          "when": "editorLangId == latex && editorHasSelection",
          "group": "navigation"
        },
        {
          "command": "latex-toolbox.unmergeSelectionFromSubfigures",
          "when": "editorLangId == latex && editorHasSelection",
          "group": "navigation"
        },
        {
          "command": "latex-toolbox.unwrapSelectionFromWrapFigure",
          "when": "editorLangId == latex && editorHasSelection",
          "group": "navigation"
        },
        {
          "command": "latex-toolbox.updateTemplateStyleFile",
          "when": "editorLangId == latex",
          "group": "navigation"
        },
        {
          "command": "latex-toolbox.registerMathSymbolReplacement",
          "when": "editorLangId == latex",
          "group": "navigation"
        },
        {
          "command": "latex-toolbox.wrapSelectionWithWrapFigure",
          "when": "editorLangId == latex && editorHasSelection",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "LatexToolBox",
      "properties": {
        "latexToolBox.clipboardImage.directory": {
          "type": "string",
          "default": "figures/paste",
          "description": "Directory, relative to the detected LaTeX project root, where clipboard images are saved."
        },
        "latexToolBox.clipboardImage.template": {
          "type": "string",
          "default": "\\begin{figure}[htbp]\n  \\centering\n  \\includegraphics[width=${width}]{${path}}\n  \\caption{$1}\n  \\label{fig:${basename}}\n\\end{figure}",
          "description": "Snippet template inserted after saving the clipboard image. Available placeholders: ${path}, ${filename}, ${basename}, ${width}."
        },
        "latexToolBox.clipboardImage.width": {
          "type": "string",
          "default": "0.8\\linewidth",
          "description": "Default width value used by ${width} in the clipboard image template."
        },
        "latexToolBox.insertImage.template": {
          "type": "string",
          "default": "\\begin{figure}[htbp]\n  \\centering\n  \\includegraphics[width=${width}]{${path}}\n  \\caption{$1}\n  \\label{fig:${basename}}\n\\end{figure}",
          "description": "Snippet template inserted after choosing an image file. Available placeholders: ${path}, ${filename}, ${basename}, ${width}."
        },
        "latexToolBox.insertImage.width": {
          "type": "string",
          "default": "0.8\\linewidth",
          "description": "Default width value used by ${width} in the file image template."
        },
        "latexToolBox.wrapFigure.position": {
          "type": "string",
          "enum": [
            "r",
            "l",
            "i",
            "o",
            "R",
            "L",
            "I",
            "O"
          ],
          "default": "r",
          "description": "Default wrapfigure placement. Common values are r for right and l for left."
        },
        "latexToolBox.wrapFigure.width": {
          "type": "string",
          "default": "0.45\\textwidth",
          "description": "Default width argument used by the wrapfigure environment."
        },
        "latexToolBox.wrapFigure.includeGraphicsWidth": {
          "type": "string",
          "default": "\\linewidth",
          "description": "Width value applied to \\includegraphics inside the wrapfigure environment."
        },
        "latexToolBox.wrapFigure.updateIncludeGraphicsWidth": {
          "type": "boolean",
          "default": true,
          "description": "Replace or add the width option on \\includegraphics when converting a selection to wrapfigure."
        },
        "latexToolBox.wrapFigure.addPackage": {
          "type": "boolean",
          "default": true,
          "description": "Automatically add \\usepackage{wrapfig} to the preamble when missing."
        },
        "latexToolBox.mathSymbols.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically replace configured text triggers with LaTeX commands while typing inside math mode."
        },
        "latexToolBox.mathSymbols.replacements": {
          "type": "object",
          "default": {
            "<=>": "\\Leftrightarrow",
            "=>": "\\Rightarrow",
            "<=": "\\leq",
            ">=": "\\geq",
            "!=": "\\neq",
            "->": "\\to",
            "<-": "\\leftarrow",
            "|->": "\\mapsto",
            "+-": "\\pm",
            "-+": "\\mp",
            "~=": "\\approx",
            "===": "\\equiv",
            "...": "\\ldots",
            "'": "^{\\prime}"
          },
          "additionalProperties": {
            "type": "string"
          },
          "description": "Text replacements applied only inside LaTeX math mode. Keys are typed triggers and values are inserted LaTeX commands."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.3"
  }
}
