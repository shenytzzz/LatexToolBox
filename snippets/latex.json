{
  "LatexToolBox Definition Box": {
    "prefix": [
      "definition",
      "definitionbox"
    ],
    "body": [
      "\\begin{definitionbox}{${1:Title}}",
      "${0:Definition content.}",
      "\\end{definitionbox}"
    ],
    "description": "Insert a LatexToolBox definitionbox environment."
  },
